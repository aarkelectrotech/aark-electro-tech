<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.aark.startup-alert</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>-c</string>
        <string>/Users/aark/bin/alert "🟢 [Aarks-Mac-mini] Mac has started up — $(date '+%A, %d %B %Y %H:%M')"</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>
